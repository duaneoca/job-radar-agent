# ── Email provider ────────────────────────────────────────────
EMAIL_PROVIDER=proton            # proton | gmail   (gmail is the cloud path)
EMAIL_READER_TRANSPORT=direct    # direct (in-process) | mcp (consume the Email Reader MCP over stdio)
# NOTE (Proton Bridge): Bridge namespaces user folders under "Folders/" and keeps the exact display
# name. "Hire Duane" in the Proton app is "Folders/Hire Duane" over IMAP. Quote it if it has spaces.
EMAIL_ROOT_FOLDER=Folders/Hire Duane
EMAIL_FOLDER_INTERACTION=Interaction
EMAIL_FOLDER_POSTINGS=Postings
EMAIL_FOLDER_SOCIAL=Social
EMAIL_FOLDER_UNPROCESSED=Unprocessed

# Proton Bridge (runs natively on this machine)
PROTON_IMAP_HOST=127.0.0.1
PROTON_IMAP_PORT=1143
PROTON_IMAP_USER=
PROTON_IMAP_PASSWORD=            # Bridge-specific password (NOT your Proton login password)

# ── Job Radar (write-back API) ────────────────────────────────
JOBRADAR_API_URL=https://job-radar.net/api
AGENT_API_KEY=                   # generate in Job Radar → Settings → Email Agent (see DEPLOYMENT.md §3)

# ── LLM (BYOK) ────────────────────────────────────────────────
# LOCAL self-host uses THESE keys directly (the agent never calls /agent/config — H6a).
# (Cloud users' keys live in their Job Radar account instead; not used here.)
LLM_PROVIDER=anthropic           # anthropic | openai | google | groq
LLM_MODEL=claude-haiku-4-5       # or a full LiteLLM model string
LLM_API_KEY=                     # your own provider key
CRITIC_MODEL=                    # optional cheaper model for the Critic; blank = same as LLM_MODEL

# ── Langfuse (optional — LLM tracing) ─────────────────────────
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Notifications (optional) ──────────────────────────────────
NOTIFIER=slack                   # slack | telegram | discord | null
SLACK_BOT_TOKEN=
SLACK_USER_CHANNEL=              # your job-activity channel (invite the bot to it)
SLACK_ADMIN_CHANNEL=            # optional ops/error channel; blank = falls back to the user channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
DISCORD_WEBHOOK_URL=
DISCORD_ADMIN_WEBHOOK_URL=
# signal | whatsapp | bluebubbles are stubs (require a relay/bridge) — not implemented

# ── Run controls / guardrails ─────────────────────────────────
MAX_EMAIL_AGE_DAYS=14            # ignore unread mail older than this (backlog control; 0 = no cutoff)
MAX_EMAILS_PER_RUN=25            # cap per run, newest-first (keeps each run quick; drains backlog over runs)
MAX_POSTINGS_PER_EMAIL=30
DAILY_SPEND_CEILING_USD=5.00     # per-day LLM spend cap on your key; 0 = disabled
POLL_INTERVAL_SECONDS=900        # only for `run` loop-mode; launchd uses the plist's StartInterval
