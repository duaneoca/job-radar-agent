# ── Email provider ────────────────────────────────────────────
EMAIL_PROVIDER=proton            # proton | gmail
EMAIL_READER_TRANSPORT=direct     # direct (in-process) | mcp (consume Email Reader MCP over stdio)
# NOTE (Proton Bridge): Bridge namespaces user folders under a "Folders/" prefix and preserves
# the exact display name (spaces/case included). A folder shown as "Hire Duane" in the Proton app
# is "Folders/Hire Duane" over IMAP. Quote it if it contains spaces. Verify with scripts/smoke_proton.py.
EMAIL_ROOT_FOLDER=Folders/Hire Duane
EMAIL_FOLDER_INTERACTION=Interaction
EMAIL_FOLDER_POSTINGS=Postings
EMAIL_FOLDER_SOCIAL=Social
EMAIL_FOLDER_UNPROCESSED=Unprocessed

# Proton Bridge (local path) — Bridge runs on the host
PROTON_IMAP_HOST=host.docker.internal
PROTON_IMAP_PORT=1143
PROTON_IMAP_USER=
PROTON_IMAP_PASSWORD=            # Bridge-specific password (NOT your Proton password)

# Gmail (cloud path) — OAuth; minimal scope (label add/remove + mark-read)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# ── Job Radar Writer MCP ──────────────────────────────────────
JOBRADAR_MCP_URL=https://job-radar.net/mcp-writer
AGENT_API_KEY=                   # per-user key minted in Job Radar settings

# ── LLM (BYOK) ────────────────────────────────────────────────
# LOCAL self-host path: the agent uses these local creds (it does NOT call /agent/config — H6a).
# CLOUD path: provider/model/key come from the user's Job Radar account via GET /agent/config.
LLM_PROVIDER=anthropic           # anthropic | openai | google | groq
LLM_MODEL=claude-sonnet-4-6      # or a full LiteLLM model string
LLM_API_KEY=                     # your own provider key (local path only)
CRITIC_MODEL=                    # optional cheaper model for the Critic; blank = same as LLM_MODEL

# ── Langfuse ──────────────────────────────────────────────────
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Notifications ─────────────────────────────────────────────
NOTIFIER=slack                   # slack | telegram | discord
SLACK_BOT_TOKEN=
SLACK_USER_CHANNEL=
SLACK_ADMIN_CHANNEL=
SLACK_SIGNING_SECRET=            # used by the job-radar callback endpoint (HITL)
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
DISCORD_WEBHOOK_URL=
DISCORD_ADMIN_WEBHOOK_URL=
# signal | whatsapp | bluebubbles are stubs (require a relay/bridge) — not implemented

# ── Run controls / guardrails ─────────────────────────────────
POLL_INTERVAL_SECONDS=900        # local in-container loop
MAX_EMAIL_AGE_DAYS=14            # ignore unread mail older than this (first-run backlog control; 0 = no cutoff)
MAX_EMAILS_PER_RUN=100           # cap per run, newest-first
MAX_POSTINGS_PER_EMAIL=30
DAILY_SPEND_CEILING_USD=5.00
HITL_ABANDON_MINUTES=30
CHECKPOINT_DB=checkpoints.db     # SQLite local; Postgres URL in cloud
ENVIRONMENT=development
